<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/logo_redcicla"
            android:contentDescription="Logo RedCicla"
            android:adjustViewBounds="true"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión de Ruta Activa"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#346739"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Card de Información de Ruta -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/txtNombreRuta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ruta: Cargando..."
                android:textStyle="bold"
                android:textColor="#2E7D32" />

            <TextView
                android:id="@+id/txtPatenteCamion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Camión: --"
                android:textColor="#4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Punto de Reciclaje"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#346739"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerPuntos"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="22dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E6E6E6"
                android:layout_marginBottom="22dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kilogramos de Vidrio (Visor Pluma)"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#346739"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/inputKgVidrio"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 340.5"
                android:inputType="numberDecimal"
                android:textSize="16sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:backgroundTint="#79AE6F"
                android:layout_marginBottom="28dp" />

            <Button
                android:id="@+id/btnGuardarRetiro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="GUARDAR RETIRO OFFLINE"
                android:textColor="#FFFFFF"
                android:backgroundTint="#346739"
                android:textStyle="bold"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnSincronizar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="SINCRONIZAR CON LA NUBE"
                android:textColor="#FFFFFF"
                android:backgroundTint="#79AE6F"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>
        <LinearLayout
            android:id="@+id/menuInferior"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:elevation="8dp"
            android:padding="8dp">

            <Button
                android:id="@+id/btnRetiroActual"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="RETIRO"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7BAF6F" />

            <Button
                android:id="@+id/btnIrMapa"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="MAPA"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2F6B3A" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>