<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/logo_redcicla"
            android:contentDescription="Logo RedCicla"
            android:adjustViewBounds="true"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registro de Retiro (Talca)"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#346739"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completa los datos del punto de retiro"
            android:textSize="15sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID Punto de Reciclaje"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#346739"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/inputPuntoId"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 105"
                android:inputType="number"
                android:textSize="16sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:backgroundTint="#79AE6F"
                android:layout_marginBottom="22dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E6E6E6"
                android:layout_marginBottom="22dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kilogramos de Vidrio (Visor Pluma)"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#346739"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/inputKgVidrio"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 340.5"
                android:inputType="numberDecimal"
                android:textSize="16sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:backgroundTint="#79AE6F"
                android:layout_marginBottom="28dp" />

            <Button
                android:id="@+id/btnGuardarRetiro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="GUARDAR RETIRO OFFLINE"
                android:textColor="#FFFFFF"
                android:backgroundTint="#346739"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>